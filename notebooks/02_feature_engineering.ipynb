  {"cell_type": "markdown", "metadata": {}, "source": ["# 02. Feature Engineering\n", "Dokumentasi proses encoding, scaling, dan justifikasi pemilihan 6 fitur model XGBoost."]},
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["import pandas as pd\nimport numpy as np\nimport joblib\nfrom sklearn.preprocessing import OrdinalEncoder, StandardScaler\n\ntrain = pd.read_csv('../data/train/train.csv')\nval   = pd.read_csv('../data/val/val.csv')\n\nFEATURES_CAT = ['day_type', 'concert_size', 'weather']\nFEATURES_NUM = ['concert_end_hour', 'time_since_end_minutes', 'distance_to_pickup_meters']\nTARGET = 'surge_multiplier'\n\nprint('Train shape:', train.shape)\nprint('Val shape:  ', val.shape)\ntrain.head()"]},
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["print('Encoding OrdinalEncoder (urutan berdasarkan logika bisnis):')\nprint('  day_type     : weekday=0, weekend=1')\nprint('  concert_size : small=0, medium=1, large=2')\nprint('  weather      : clear=0, cloudy=1, rain=2')\nprint()\nprint('Alasan OrdinalEncoder vs OneHotEncoder:')\nprint('- Ketiga fitur memiliki urutan logis (ordinal)')\nprint('- XGBoost dapat memanfaatkan urutan ini langsung')\nprint('- Menghindari dimensionality explosion dari OneHot')"]},
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["print('Statistik sebelum scaling:')\nprint(train[FEATURES_NUM].describe().round(2))\nencoder = joblib.load('../models/encoder.pkl')\nscaler  = joblib.load('../models/scaler.pkl')\nprint('\\nMean per fitur:', scaler.mean_.round(2))\nprint('Std per fitur :', scaler.scale_.round(2))"]},
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["justifikasi = {\n    'concert_end_hour'         : 'Jam larut = ojol langka = surge tinggi',\n    'day_type'                 : 'Weekend = demand lebih tinggi',\n    'concert_size'             : 'Kapasitas = volume penonton keluar bersamaan',\n    'weather'                  : 'Hujan = permintaan ojol melonjak drastis',\n    'time_since_end_minutes'   : 'Decay surge seiring waktu',\n    'distance_to_pickup_meters': 'Makin jauh dari venue = surge lebih rendah',\n}\nprint('Justifikasi 6 Fitur:\\n')\nfor feat, reason in justifikasi.items():\n    print(f'  {feat:<32} : {reason}')"]},
  {"cell_type": "markdown", "metadata": {}, "source": ["## Keputusan Feature Engineering\n", "- OrdinalEncoder dipilih karena fitur kategorikal memiliki urutan logis\n", "- StandardScaler memastikan fitur numerik pada skala yang sama\n", "- Encoder dan scaler di-fit hanya pada train set (no data leakage)"]]}
